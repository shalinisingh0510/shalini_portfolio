{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/about/",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/skills/",
      "destination": "/skills",
      "permanent": true
    },
    {
      "source": "/projects/",
      "destination": "/projects",
      "permanent": true
    },
    {
      "source": "/resume/",
      "destination": "/resume",
      "permanent": true
    },
    {
      "source": "/contact/",
      "destination": "/contact",
      "permanent": true
    }
  ]
}